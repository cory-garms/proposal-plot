# ============================================================
# ProposalPilot AI — environment configuration
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================

# ---- Auth (REQUIRED) ----------------------------------------
# Generate a real secret before deploying:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-before-deploy


# ---- LLM Provider (choose one block) -----------------------

# Option A: Anthropic (default)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Option B: OpenAI
# LLM_PROVIDER=openai_compat
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...

# Option C: Google Gemini
# LLM_PROVIDER=openai_compat
# LLM_MODEL=gemini-2.0-flash
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=AIza...

# Option D: Moonshot / Kimi K2
# LLM_PROVIDER=openai_compat
# LLM_MODEL=kimi-k2
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_API_KEY=sk-...

# Option E: Zhipu / GLM
# LLM_PROVIDER=openai_compat
# LLM_MODEL=glm-4
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# LLM_API_KEY=...

# Option F: Ollama (local, no API key needed)
# LLM_PROVIDER=openai_compat
# LLM_MODEL=llama3.2
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_API_KEY=   # leave blank

# Option G: LM Studio (local)
# LLM_PROVIDER=openai_compat
# LLM_MODEL=your-loaded-model-name
# LLM_BASE_URL=http://host.docker.internal:1234/v1
# LLM_API_KEY=   # leave blank

# Option H: vLLM / HuggingFace TGI (self-hosted)
# LLM_PROVIDER=openai_compat
# LLM_MODEL=meta-llama/Llama-3.2-8B-Instruct
# LLM_BASE_URL=http://your-server:8001/v1
# LLM_API_KEY=   # set if your deployment requires one


# ---- Database -----------------------------------------------
# Local dev: relative path (default)
DB_PATH=proposalpilot.db
# Render production: persistent disk mount
# DB_PATH=/data/proposalpilot.db


# ---- CORS ---------------------------------------------------
# Local dev: open (default)
CORS_ORIGINS=*
# Production: restrict to your GitHub Pages URL
# CORS_ORIGINS=https://cory-garms.github.io


# ---- Optional scraper keys ----------------------------------
# SAM.gov API key — increases rate limit from 10 to 100 req/min.
# Free registration: https://sam.gov/profile/details
SAM_API_KEY=
